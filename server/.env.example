PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/resort-scheduler
CLIENT_URL=https://your-app.vercel.app

# GoHighLevel Integration
GHL_PAYMENT_URL=https://your-ghl-order-form-url.com
GHL_WEBHOOK_SECRET=your-shared-secret-here

# Admin Alerts (Gmail SMTP via Nodemailer)
# Fires when a GHL "paid" webhook arrives with no matching pending booking.
# ALERT_EMAIL_PASSWORD must be a Gmail App Password (requires 2FA on the account).
# Generate at: https://myaccount.google.com/apppasswords
# ALERT_EMAIL_TO supports comma-separated recipients.
ALERT_EMAIL_USER=your.email@gmail.com
ALERT_EMAIL_PASSWORD=your-16-char-app-password
ALERT_EMAIL_TO=admin@example.com
